# Copy this file to .env.daytona.local and fill in your own values.
# Do not commit .env.daytona.local.

DAYTONA_API_KEY=

# Fork-capable demo target discovered by npm run daytona:probe-fork.
# Set DAYTONA_USE_DEFAULT_SANDBOX=1 if you intentionally want Daytona's default container sandbox.
DAYTONA_TARGET=us-east-1

# Fork-capable linux-vm snapshot discovered by npm run daytona:probe-fork.
# The live runner also has fallback linux-vm snapshots if this one has a transient start issue.
DAYTONA_BASE_SNAPSHOT=daytona-vm-medium

# Demo sandboxes auto-stop after 15 minutes of inactivity. Set to another
# non-negative integer only when you need a different recording window.
DAYTONA_DEMO_AUTOSTOP_MINUTES=15

# Cleanup is enabled by default. Set DAYTONA_KEEP_SANDBOXES=1 only when
# you explicitly want to inspect the fork tree after the command exits.
DAYTONA_KEEP_SANDBOXES=0
